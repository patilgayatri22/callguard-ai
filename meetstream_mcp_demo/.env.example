# Scalekit credentials — from app.scalekit.com → Settings → API Credentials
SK_ENV_URL=https://your-env.scalekit.dev
SK_CLIENT_ID=skc_your_client_id
SK_CLIENT_SECRET=test_your_client_secret

# Server
PORT=3002
PUBLIC_URL=http://localhost:3002

# MCP Server ID (from Scalekit dashboard → Agent Actions → MCP Servers)
MCP_SERVER_ID=res_your_server_id

# Protected Resource Metadata
PROTECTED_RESOURCE_METADATA={"authorization_servers":["https://your-env.scalekit.dev"],"bearer_methods_supported":["header"],"resource":"http://localhost:3002/","scopes_supported":["gmail:read"]}

# ── MeetStream ↔ ngrok handshake ──────────────────────────────────────────────
# Static Bearer token MeetStream sends to THIS server.
# Generate with: openssl rand -hex 32
# The result will be a 64-character hex string — give that value to MeetStream
# as the Authorization header token, e.g.: Authorization: Bearer <64-char-hex>
MCP_BEARER_TOKEN=your_generated_token_here

# Your friend's raw ngrok MCP server URL (no auth required on that end).
# When set, ALL authenticated MCP requests are forwarded here (Authorization header stripped).
# When unset, Gmail tools are executed locally via Scalekit Agent Actions.
MCP_UPSTREAM_URL=https://your-friend.ngrok-free.app
